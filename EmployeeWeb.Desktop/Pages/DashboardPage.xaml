<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EmployeeWeb.Desktop.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="24">
            <TextBlock Text="COMPANY OVERVIEW" FontSize="20" FontWeight="SemiBold" Foreground="#333333"/>

            <ProgressRing x:Name="LoadingRing" IsActive="True" Visibility="Visible" HorizontalAlignment="Center" Margin="0,24"/>

            <Grid x:Name="ContentGrid" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Daily Activity Snapshot -->
                <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="8" Padding="16" Margin="0,0,12,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DAILY ACTIVITY SNAPSHOT" FontWeight="Medium" Foreground="#555555"/>
                        <Rectangle Height="1" Fill="#EEEEEE" Margin="0,4,0,4"/>
                        <TextBlock Text="ACTIVE EMPLOYEES" Foreground="#666" FontSize="12"/>
                        <TextBlock x:Name="ActiveTotalText" Text="0 / 0" FontSize="18" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="ActivityProgress" Value="0" Maximum="100" Height="8" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total on break -->
                <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="8" Padding="16" Margin="12,0,0,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TOTAL EMPLOYEES ON BREAK" FontWeight="Medium" Foreground="#555555"/>
                        <Rectangle Height="1" Fill="#EEEEEE" Margin="0,4,0,4"/>
                        <TextBlock x:Name="OnBreakText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2196F3"/>
                    </StackPanel>
                </Border>

                <!-- Medium breaks card -->
                <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Employees with medium breaks (45M - 1.5H)" Foreground="#FF9800" FontWeight="SemiBold"/>
                        <ListView x:Name="MediumBreakList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="BreakEmployee_Click">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#666" Margin="0,4"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Long breaks card -->
                <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="8" Padding="16" Margin="12,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Employees with long break (1.5H +)" Foreground="#D32F2F" FontWeight="SemiBold"/>
                        <ListView x:Name="LongBreakList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="BreakEmployee_Click">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#666" Margin="0,4"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
