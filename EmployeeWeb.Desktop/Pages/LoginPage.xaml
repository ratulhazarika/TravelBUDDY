<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EmployeeWeb.Desktop.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Gradient brush: #4f46e5 -> #6c5ffc (matches React loginPage.module.css) -->
        <LinearGradientBrush x:Key="LoginGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4f46e5" Offset="0"/>
            <GradientStop Color="#5b4ff5" Offset="0.4"/>
            <GradientStop Color="#6c5ffc" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>

    <Grid Background="{StaticResource LoginGradient}">
        <ScrollViewer VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Padding="24">
                <!-- Paper 1: Login card (matches React Paper elevation + rounded) -->
                <Border Background="#D9FFFFFF" CornerRadius="12" Padding="32">
                    <StackPanel Spacing="16">
                        <!-- Logo area - loaded from URL in code-behind -->
                        <Image x:Name="LogoImage" Width="140" Height="70" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock Text="Travelogy HR Login" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Secure access for administrative personnel."
                                   Foreground="#555555" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <!-- Email (matches React: label "HR Email Address") -->
                        <TextBox x:Name="EmailBox" Header="HR Email Address" PlaceholderText="HR Email Address"
                                 InputScope="EmailSmtpAddress"/>
                        <!-- Password (matches React: label "Password") -->
                        <PasswordBox x:Name="PasswordBox" Header="Password" PlaceholderText="Password"/>
                        <TextBlock x:Name="ErrorText" Foreground="Red" Text="" Visibility="Collapsed" TextWrapping="Wrap"/>
                        <Button x:Name="SignInButton" Content="Sign In" Click="SignInButton_Click"
                                HorizontalAlignment="Stretch" Padding="0,14" FontWeight="SemiBold" FontSize="16"/>
                    </StackPanel>
                </Border>
                <!-- Paper 2: Travel Buddy download -->
                <Border Background="#D9FFFFFF" CornerRadius="12" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE72E;" FontSize="24" Foreground="#4f46e5"/>
                        <TextBlock Text="Download Travel Buddy App" FontWeight="Bold" FontSize="16"/>
                    </StackPanel>
                    <TextBlock Text="Enhance your experience in Travelogy company with Travel Buddy native desktop application."
                               Foreground="#555555" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Button Content="Windows" Click="DownloadWindows_Click"
                            HorizontalAlignment="Center" Padding="24,12" Background="#2E7D32"/>
                </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <ProgressRing x:Name="LoginProgress" IsActive="False" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Page>
